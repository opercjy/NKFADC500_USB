[GLOBAL]
# ==============================================================================
# Notice KFADC500 Hardware Identification
# ==============================================================================
VID = 0x0547
PID = 0x1080

# ==============================================================================
# Data Acquisition & Trigger Settings
# ==============================================================================
# [ INPUT_FILTER ] 
# 0 = Bypassed Mode (Raw 신호 그대로 획득)
# 1 = Filtered Mode (하드웨어 노이즈 필터 적용)
INPUT_FILTER = 0

# [ RECORD_LENGTH ] : 물리 이벤트의 파형 기록 윈도우 크기
# KFADC500은 500MS/s (1샘플 = 2ns)로 동작합니다. 대상 섬광체에 맞춰 설정하세요.
#   4  = 512 ns  (액체/플라스틱 섬광체, PMT Dark Noise 측정용)
#   8  = 1 us    (LYSO, CeBr3 등 감쇠 시간이 비교적 빠른 무기 섬광체용)
#   16 = 2 us    (NaI(Tl), CsI(Tl), BGO 등 감쇠 시간이 긴 무기 섬광체용)
#   32 = 4 us    (극단적으로 꼬리가 긴 신호용)
RECORD_LENGTH = 16

# [ TRIGGER_LUT ] : 16-bit Coincidence & Trigger Logic (Hex 지원)
# 0xFFFE = OR Trigger (CH 1~4 중 하나라도 Threshold를 넘으면 전체 기록)
# 0x8000 = 4-Fold AND Coincidence (4개 채널 모두 신호가 들어와야 기록)
# 0x0002 = CH1 Only (CH1 트리거만 허용, 나머지 무시. 단일 채널 캘리브레이션용)
TRIGGER_LUT = 0xFFFE

# ==============================================================================
# Pulse Processing & Deadtime Constraints (하드웨어 로직)
# ==============================================================================
PULSE_COUNT_EN = 1
PULSE_WIDTH_EN = 1
PULSE_COUNT_THR = 1
PULSE_COUNT_INT = 1
PULSE_WIDTH_THR = 10
DEADTIME = 0
COINCIDENCE_WIDTH = 100


# ==============================================================================
# Channel Specific Settings (CH0~CH3은 물리적인 CH1~CH4에 매핑됨)
# ==============================================================================
[CH0]
# [ OFFSET ] : ADC Baseline 페데스탈 위치. (0~4095, 보통 3500 권장)
OFFSET = 3500

# [ DELAY ] : Pre-trigger (프리트리거) 지연 시간. (단위: ns)
# DELAY = 100 인 경우 800ns를 지연시킴. Record Length를 2us(16)로 늘릴 경우, 
# 펄스가 윈도우의 앞쪽에 예쁘게 위치하도록 이 값을 함께 조절해야 합니다.
DELAY = 600

# [ POLARITY ] : 입력 신호의 극성. 
# 0 = Negative (음전압, 일반적인 PMT Anode 직결 신호)
# 1 = Positive (양전압, Pre-amp를 거친 신호)
POLARITY = 0

# [ THRESHOLD ] : 하드웨어 트리거를 발생시키는 문턱값 (ADC 카운트 단위)
# 페데스탈 출렁임(노이즈)에 의한 가짜 트리거를 막을 수 있는 최적의 값을 찾아야 함.
THRESHOLD = 100

[CH1]
OFFSET = 3500
DELAY = 600
POLARITY = 0
THRESHOLD = 100

[CH2]
OFFSET = 3500
DELAY = 600
POLARITY = 0
THRESHOLD = 100

[CH3]
OFFSET = 3500
DELAY = 600
POLARITY = 0
THRESHOLD = 100